// =====================================================
// 라라댄스 출석 관리 시스템 — Firestore 보안 규칙
// =====================================================
// 적용 방법:
//   Firebase 콘솔 → Firestore Database → 규칙 탭
//   아래 내용을 전체 복사 후 붙여넣기 → 게시
// =====================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isTeacherOrAdmin() {
      return isAuth() && myRole() in ['teacher', 'admin'];
    }
    function isAdmin() {
      return isAuth() && myRole() == 'admin';
    }

    // ── 수업 목록 (메인 홈도 읽음 → 공개 읽기) ────
    match /classes/{id} {
      allow read:  if true;
      allow write: if isTeacherOrAdmin();
    }

    // ── 수업 안내 카드 (메인 홈 공개) ─────────────
    match /classinfo/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── 학원 소식 (메인 홈 공개) ──────────────────
    match /news/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── 출석 기록 ─────────────────────────────────
    match /checkins/{id} {
      allow read:   if isAuth();
      // 본인 출석만 생성/삭제 가능, 선생님·관리자는 전체 가능
      allow create: if isAuth() &&
        (request.resource.data.userId == request.auth.uid || isTeacherOrAdmin());
      allow delete: if isAuth() &&
        (resource.data.userId == request.auth.uid || isTeacherOrAdmin());
    }

    // ── 수강 등록 ─────────────────────────────────
    match /enrolled/{userId} {
      allow read:  if isAuth();
      allow write: if isAuth() &&
        (request.auth.uid == userId || isAdmin());
    }

    // ── 사용자 프로필 ─────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth();
      // 본인 계정 생성, 수정·삭제는 관리자만
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── 설정 (학원코드, 활성수업 등) ──────────────
    // codes 문서는 가입 시 미인증 상태에서도 읽어야 하므로 공개 허용
    match /settings/{id} {
      allow read:  if id == 'codes' || isAuth();
      allow write: if isAdmin();
    }
  }
}
